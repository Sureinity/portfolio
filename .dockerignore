# Keep Docker build context small and deterministic.
node_modules
.next
out
build
coverage

# Git and editor metadata are not needed inside the image.
.git
.gitignore
.vercel
.vscode
.idea

# Local environment files should be supplied through Compose/runtime config.
.env
.env.*
!.env.example

# Local logs and package manager noise.
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# OS and temporary files.
.DS_Store
*.pem
*.tsbuildinfo

