# Copy this file to .env on the production server.
# Then deploy with:
# docker compose --env-file .env -f docker-compose.prod.yml up -d --build

# Domain that should serve the portfolio.
# Example: portfolio.example.com
PORTFOLIO_DOMAIN=portfolio.example.com

# Email used by Let's Encrypt for certificate notices.
TRAEFIK_ACME_EMAIL=admin@example.com

# Optional: keep default unless you intentionally rename the Docker network.
TRAEFIK_NETWORK=portfolio-web

# Optional: Traefik certificate resolver name used in labels and ACME config.
TRAEFIK_CERTRESOLVER=letsencrypt

# Optional: set true only if you also add a secure dashboard router.
TRAEFIK_DASHBOARD=false

# Optional: DEBUG is useful during first deployment, INFO is better after.
TRAEFIK_LOG_LEVEL=INFO

